{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/*.{css,scss,sass,js,json,ico,svg,png,jpg,jpeg,gif,webp,woff,woff2,ttf,eot,otf}"
    ]
  },
  "routes": [
    {
      "route": "/api/*",
      "methods": ["get", "post"],
      "allowedRoles": ["anonymous"]
    }
  ],
  "platform": {
    "apiRuntime": "dotnet-isolated:9.0"
  }
}
