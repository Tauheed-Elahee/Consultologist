---
import Layout from "../layouts/Layout.astro";
import "../styles/contact.css";

// Public Turnstile site key for the "Consultologist contact form" widget.
const TURNSTILE_SITE_KEY = "0x4AAAAAADxoztWEBRdCjE27";
---

<Layout
    title="Contact — Consultologist"
    description="Get in touch with Consultologist: join the waitlist, ask a question, or make a privacy request. We read everything and reply by email."
>
    <section class="contact-section">
        <div class="section-header">
            <span class="section-eyebrow">Contact</span>
            <h2>Join the Waitlist · Get in Touch</h2>
            <p class="section-description">
                Join the waitlist, ask a question, or make a privacy request. If you're joining
                the waitlist, tell us about your specialty and consult volume so we can follow
                up when early access is ready for your workflow.
            </p>
        </div>

        <div class="card contact-card">
            <form class="contact-form" id="contact-form" novalidate>
                <label class="input-field">
                    <span>Full name</span>
                    <input type="text" name="name" placeholder="Dr. Jane Smith" required />
                </label>

                <label class="input-field">
                    <span>Email</span>
                    <input type="email" name="email" placeholder="you@clinic.ca" required />
                </label>

                <label class="input-field">
                    <span>Specialty (optional)</span>
                    <input
                        type="text"
                        name="specialty"
                        placeholder="Oncology, Rheumatology, etc."
                    />
                </label>

                <label class="input-field">
                    <span>Institution (optional)</span>
                    <input type="text" name="organization" placeholder="City Hospital" />
                </label>

                <label class="input-field">
                    <span>Message (optional)</span>
                    <textarea
                        name="comments"
                        placeholder="What would you like to tell us or ask us?"
                        rows="6"></textarea>
                </label>

                <div class="trap-field" aria-hidden="true">
                    <label>
                        Website
                        <input type="text" name="website" tabindex="-1" autocomplete="off" />
                    </label>
                </div>

                <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>

                <div class="form-actions">
                    <button type="submit" class="btn-accent" id="contact-submit">
                        Send message
                    </button>
                </div>
            </form>

            <div class="response-card" id="form-response" aria-live="polite" hidden>
                <div class="loading-message" id="form-loading" hidden>
                    <div class="spinner" role="progressbar" aria-label="Sending"></div>
                    <p>Sending your message...</p>
                </div>
                <div class="success-message" id="form-success" hidden>
                    <p></p>
                </div>
                <div class="error-message" id="form-error" hidden>
                    <h3>We ran into an issue</h3>
                    <p></p>
                </div>
            </div>
        </div>
    </section>

    <script
        is:inline
        src="https://challenges.cloudflare.com/turnstile/v0/api.js"
        async
        defer></script>
    <script src="../scripts/contact-form.ts"></script>
</Layout>
